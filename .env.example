# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de entorno — SOLO datos de prueba / placeholders.
# Copiar a .env y reemplazar con valores reales de tu entorno (no commitear .env).
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos de control (SQL Server)
DB_CLIENT=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=dev_user
DB_PASSWORD=change_me_in_local_env
DB_NAME=control_db_dev
DB_SSL=false
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# Prisma (opcional). Si se omite, los scripts db:* y la app arman la URL desde DB_*
# DATABASE_URL="sqlserver://localhost:1433;database=control_db_dev;user=dev_user;password=change_me_in_local_env;encrypt=false;trustServerCertificate=true"

# Llave maestra AES-256 (32 bytes en Base64). Generar la tuya con:
#   npm run encrypt-password -- --generate-key
ENCRYPTION_KEY=

# API
API_HOST=0.0.0.0
API_PORT=3000

# ETL: true = dataset simulado de SAP (recomendado en desarrollo)
ETL_SAP_MOCK=true
