# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de entorno — SOLO placeholders. NO incluir credenciales ni IPs reales.
# Copiar a .env y completar con valores de tu entorno (nunca commitear .env).
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos de control (SQL Server)
DB_CLIENT=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=dev_user
DB_PASSWORD=change_me_in_local_env
DB_NAME=control_db_dev
DB_SSL=false
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# Prisma (opcional). Si se omite, los scripts db:* y la app arman la URL desde DB_*
# DATABASE_URL="sqlserver://localhost:1433;database=control_db_dev;user=dev_user;password=change_me_in_local_env;encrypt=false;trustServerCertificate=true"

# Llave maestra AES-256 (32 bytes en Base64). Generar la tuya con:
#   npm run encrypt-password -- --generate-key
ENCRYPTION_KEY=

# API
API_HOST=0.0.0.0
API_PORT=3000

# ETL: true = dataset simulado de SAP (recomendado en desarrollo)
ETL_SAP_MOCK=true

# SAP — Sybase ASE (Java/jConnect; requiere Java 17+ en PATH, sin licencia ODBC)
ETL_SAP_SOURCE=sybase
SYBASE_SERVER=
SYBASE_PORT=4901
SYBASE_UID=
SYBASE_PWD=
SYBASE_DATABASE=
SYBASE_USE_SERVICENAME=false

# ─────────────────────────────────────────────────────────────────────────────
# Active Directory (LDAP) — sincronización de usuarios en tbl_users
# Completar en .env local; dejar vacíos los secretos en el repositorio.
# ─────────────────────────────────────────────────────────────────────────────
LDAP_URL=ldap://ldap.example.local:389
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=svc-ldap@example.local
LDAP_BIND_PASSWORD=
LDAP_DOMAIN_NETBIOS=EXAMPLE
LDAP_LOGIN_UPN_SUFFIX=example.local
LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={{username}})(!(userAccountControl:1.2.840.113556.1.4.803:=2)))
LDAP_ATTRIBUTES=cn,sAMAccountName,displayName,givenName,sn,mail,Department,Company,physicalDeliveryOfficeName,employeeID,employeeType,title,st,distinguishedName
LDAP_SYNC_FILTER=(&(objectClass=user)(samaccountname=*)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))
LDAP_PAGE_SIZE=500
LDAP_SYNC_DEACTIVATE_MISSING=true
LDAP_DEFAULT_ROLE_ID=
LDAP_DEFAULT_ROLE_NAME=user
LDAP_SYNC_CRON_ENABLED=true
LDAP_SYNC_CRON=0 2 * * *
LDAP_SYNC_CRON_TIMEZONE=

# JWT — login con Active Directory
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Login — solo departamento IT (campo department sincronizado desde AD)
LOGIN_IT_DEPARTMENT_NAME=IT
LOGIN_IT_DEPARTMENT_ALIASES=TECNOLOGIA,INFORMATICA
